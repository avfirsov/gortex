{
  "name": "@gortex/wire",
  "version": "0.1.0",
  "description": "TypeScript decoder for the GCX1 compact wire format (see docs/wire-format.md in the gortex repo)",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --experimental-strip-types --test test/decode.test.ts test/golden.test.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "gortex",
    "mcp",
    "code-intelligence",
    "wire-format",
    "gcx"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/zzet/gortex.git",
    "directory": "packages/wire-ts"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
